{
  "info": {
    "name": "Product Management Microservices",
    "description": "Gateway-based collection for auth, authorization, product, cart, order, and event APIs. Login requests automatically store JWTs. Product/cart creation requests automatically store generated identifiers.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "adminEmail", "value": "admin@example.com" },
    { "key": "adminPassword", "value": "Admin@123" },
    { "key": "userName", "value": "John Doe" },
    { "key": "userEmail", "value": "john@example.com" },
    { "key": "userPassword", "value": "Password@123" },
    { "key": "department", "value": "SALES" },
    { "key": "region", "value": "APAC" },
    { "key": "adminToken", "value": "" },
    { "key": "userToken", "value": "" },
    { "key": "userId", "value": "" },
    { "key": "productId", "value": "" },
    { "key": "cartItemId", "value": "" }
  ],
  "item": [
    {
      "name": "01 Auth",
      "item": [
        {
          "name": "01 Register First User",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 201', function () { pm.response.to.have.status(201); });",
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('userToken', json.token);",
                  "pm.collectionVariables.set('userId', String(json.userId));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"{{userName}}\",\n  \"email\": \"{{userEmail}}\",\n  \"password\": \"{{userPassword}}\",\n  \"department\": \"{{department}}\",\n  \"region\": \"{{region}}\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/register"
          }
        },
        {
          "name": "02 Login User",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('userToken', json.token);",
                  "pm.collectionVariables.set('userId', String(json.userId));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{userEmail}}\",\n  \"password\": \"{{userPassword}}\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/login"
          }
        },
        {
          "name": "03 Login Default Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('adminToken', json.token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/login"
          }
        }
      ]
    },
    {
      "name": "02 User And Authorization",
      "item": [
        {
          "name": "04 Get Current User",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('userId', String(json.id));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }],
            "url": "{{baseUrl}}/api/users/me"
          }
        },
        {
          "name": "05 Authorization Check",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{userToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"resourceOwnerId\": {{userId}},\n  \"resourceDepartment\": \"{{department}}\",\n  \"resourceRegion\": \"{{region}}\",\n  \"action\": \"READ\"\n}"
            },
            "url": "{{baseUrl}}/api/authorization/check"
          }
        }
      ]
    },
    {
      "name": "03 Products",
      "item": [
        {
          "name": "06 Create Product",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 201', function () { pm.response.to.have.status(201); });",
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('productId', String(json.id));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Laptop\",\n  \"description\": \"16GB RAM, 512GB SSD\",\n  \"price\": 79999.99,\n  \"quantity\": 10\n}"
            },
            "url": "{{baseUrl}}/api/products"
          }
        },
        {
          "name": "07 List Products",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }],
            "url": "{{baseUrl}}/api/products"
          }
        },
        {
          "name": "08 Get Product By Id",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }],
            "url": "{{baseUrl}}/api/products/{{productId}}"
          }
        },
        {
          "name": "09 Update Product",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Laptop Pro\",\n  \"description\": \"32GB RAM, 1TB SSD\",\n  \"price\": 99999.99,\n  \"quantity\": 15,\n  \"enabled\": true\n}"
            },
            "url": "{{baseUrl}}/api/products/{{productId}}"
          }
        },
        {
          "name": "10 Update Product Status",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"enabled\": true\n}"
            },
            "url": "{{baseUrl}}/api/products/{{productId}}/status"
          }
        }
      ]
    },
    {
      "name": "04 Cart",
      "item": [
        {
          "name": "11 Add Item To Cart",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
                  "const json = pm.response.json();",
                  "if (json.items && json.items.length > 0) { pm.collectionVariables.set('cartItemId', String(json.items[0].cartItemId)); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{userToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": {{productId}},\n  \"quantity\": 2\n}"
            },
            "url": "{{baseUrl}}/api/cart/items"
          }
        },
        {
          "name": "12 View Cart",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
                  "const json = pm.response.json();",
                  "if (json.items && json.items.length > 0) { pm.collectionVariables.set('cartItemId', String(json.items[0].cartItemId)); }"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }],
            "url": "{{baseUrl}}/api/cart/get-items"
          }
        },
        {
          "name": "13 Update Cart Item",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{userToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"quantity\": 3\n}"
            },
            "url": "{{baseUrl}}/api/cart/items/{{cartItemId}}"
          }
        },
        {
          "name": "14 Remove Cart Item",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }],
            "url": "{{baseUrl}}/api/cart/items/{{cartItemId}}"
          }
        },
        {
          "name": "15 Re-Add Item For Ordering",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{userToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": {{productId}},\n  \"quantity\": 1\n}"
            },
            "url": "{{baseUrl}}/api/cart/items"
          }
        }
      ]
    },
    {
      "name": "05 Orders",
      "item": [
        {
          "name": "16 Place Order",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }],
            "url": "{{baseUrl}}/api/orders"
          }
        },
        {
          "name": "17 Get My Orders",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }],
            "url": "{{baseUrl}}/api/orders"
          }
        }
      ]
    },
    {
      "name": "06 Events",
      "item": [
        {
          "name": "18 List Consumed Events",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/events"
          }
        }
      ]
    }
  ]
}
